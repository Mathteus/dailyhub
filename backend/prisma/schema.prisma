generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Accounts {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  salt String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@map("acounts")
}
 
