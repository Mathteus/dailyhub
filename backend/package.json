{
	"name": "dailyhub-backend",
	"version": "0.0.1",
	"description": "Backend do DailyHub",
	"author": "Matheus Henrique",
	"private": true,
	"license": "Apache-2.0",
	"scripts": {
		"build": "bunx --bun nest build",
		"format": "bunx --bun @biomejs/biome format --write",
		"start": "bunx --bun nest start",
		"dev": "nest --env-file=.env start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "bunx --bun eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "bunx --bun vitest",
		"test:cov": "bunx --bun vitest --coverage"
	},
	"dependencies": {
		"@apollo/server": "^5.5.0",
		"@as-integrations/express5": "^1.1.2",
		"@casl/ability": "^6.8.0",
		"@nestjs/apollo": "^13.2.5",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.0.1",
		"@nestjs/graphql": "^13.2.5",
		"@nestjs/platform-express": "^11.0.1",
		"@prisma/adapter-better-sqlite3": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"@types/bun": "^1.3.12",
		"argon2": "^0.44.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"dotenv": "^17.4.1",
		"graphql": "^16.13.2",
		"nanoid": "^5.1.7",
		"prisma": "^7.7.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@eslint/eslintrc": "^3.2.0",
		"@eslint/js": "^9.18.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/testing": "^11.0.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.5.2",
		"@types/supertest": "^6.0.2",
		"@vitest/coverage-v8": "4.1.4",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"prettier": "^3.8.1",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.20.0",
		"vitest": "^4.1.4"
	},
	"jest": {
		"moduleFileExtensions": ["js", "json", "ts"],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": ["**/*.(t|j)s"],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
